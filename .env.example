# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CLERK AUTHENTICATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Get these from: https://dashboard.clerk.com/apps/[your-app]/api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXX

# Sign-in/Sign-up URLs (used by Clerk redirects)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# After sign-in redirect (optional, defaults to /)
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/guided/step-1

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CLERK JWT ISSUER (for Convex integration)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Get this from: Clerk Dashboard → JWT Templates → convex template → Issuer
# ⚠️ IMPORTANT: Domain only, WITHOUT https://
# ✅ Correct: your-app.clerk.accounts.dev
# ❌ Wrong: https://your-app.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=your-app.clerk.accounts.dev

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CONVEX BACKEND
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Get these after running: npx convex dev
# ⚠️ IMPORTANT: Both URLs must be identical and include https://

# For prebuild script (Vercel deployment)
CONVEX_URL=https://your-project.convex.cloud

# For client-side connection
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI SERVICES (Optional - Phase 3)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Get from: https://fal.ai/dashboard/keys
# FAL_KEY=your_key_id:your_key_secret

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI SERVICES (Sprint 5)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# OpenAI API (chat route + translation script)
# Used by: app/api/chat/route.ts (via @ai-sdk/openai) and scripts/translate.js
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXX

# Together.ai API (Fallback text generation)
# Get from: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXX

# fal.ai API (Image generation)
# Get from: https://fal.ai/dashboard/keys
# Format: key_id:key_secret
FAL_KEY=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RESEND (Transactional Email)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Get from: https://resend.com/api-keys
# Must be set in Convex dashboard too (npx convex env set RESEND_API_KEY re_xxx)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXX

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# E2E TESTING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Browserbase — optional; e2e tests run locally without these.
# When set, Playwright connects to Browserbase cloud browsers via WebSocket
# instead of launching a local Chromium. Get from: https://browserbase.com
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Clerk Testing Mode — OTP bypass for e2e authenticated tests.
# Generate from: Clerk Dashboard → Testing → Testing tokens
# Tests skip automatically when this is absent.
CLERK_TESTING_TOKEN=

# Base URL for Playwright tests (defaults to http://localhost:3000)
PLAYWRIGHT_BASE_URL=http://localhost:3000
