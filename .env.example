# ══════════════════════════════════════════════════════════════
# ENVIRONMENT VARIABLES — VantageStarter
#
# This file is the CONTRACT: every variable listed here is either
# read directly via `process.env.*` somewhere in this repository,
# or read internally by a vendor SDK (Clerk, Resend/@convex-dev/resend,
# Polar) that we do not control the source of. Nothing is listed
# "just in case" — if a name is not read anywhere, it does not
# belong here, because a stranger cloning this repo cannot tell
# the difference between "load-bearing" and "leftover".
#
# REQUIRED = the app will visibly break (auth error, blank screen,
#            or a named console/runtime error) without it.
# OPTIONAL = the app runs and falls back to a sane default; only
#            needed to unlock a specific feature.
# TOOLING  = read only by test/build scripts, never by the running
#            app. A stranger doing local dev does not need these.
# ══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# REQUIRED — Clerk (authentication)
# ─────────────────────────────────────────────────────────────
# Get both from: https://dashboard.clerk.com/apps/[your-app]/api-keys
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY is read internally by @clerk/nextjs's
# ClerkProvider (node_modules/@clerk/nextjs/.../mergeNextClerkPropsWithEnv.js) —
# no explicit process.env read exists in this repo's own code, but the SDK
# requires it to boot. Without it: "Clerk: missing publishable key" and a
# blank first screen.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXX

# Get from: Clerk Dashboard → JWT Templates → convex template → Issuer
# ⚠️ Domain only, WITHOUT https:// — e.g. your-app.clerk.accounts.dev
# Must ALSO be set in the Convex dashboard (Settings → Environment Variables) —
# Convex functions run in their own runtime and cannot read this file.
CLERK_JWT_ISSUER_DOMAIN=your-app.clerk.accounts.dev

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Clerk custom domain (CSP allow-list)
# ─────────────────────────────────────────────────────────────
# Read by lib/csp.mjs (shared by middleware.ts and next.config.mjs) to add
# your custom/satellite Clerk domain to script-src and frame-src.
# LEAVE UNSET if you use Clerk's development domain (*.clerk.accounts.dev is
# always allowed — a fork works with no value here). Set only once you
# configure a Clerk custom domain in production. With or without https://.
NEXT_PUBLIC_CLERK_DOMAIN=

# ─────────────────────────────────────────────────────────────
# REQUIRED — Convex backend
# ─────────────────────────────────────────────────────────────
# Both auto-written by running: pnpm exec convex dev (do not hand-type these —
# the Convex CLI derives them for you). Without NEXT_PUBLIC_CONVEX_URL:
# "Could not connect to Convex" and a non-functional first screen.
CONVEX_DEPLOYMENT=dev:your-project-name
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# ─────────────────────────────────────────────────────────────
# REQUIRED — OpenAI (chat)
# ─────────────────────────────────────────────────────────────
# Used by: app/api/chat/route.ts (via @ai-sdk/openai) and scripts/translate.js.
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Resend (transactional email)
# ─────────────────────────────────────────────────────────────
# Read internally by the resend package and the @convex-dev/resend Convex
# component (both default to process.env.RESEND_API_KEY when no apiKey is
# passed explicitly — see convex/email.ts). Absent key: welcome/billing
# emails fail silently (caught) and the signup/checkout flow itself still
# completes — this is why it is optional, not required, for a first screen.
# Get from: https://resend.com/api-keys
# Must be set in the Convex dashboard too (pnpm exec convex env set RESEND_API_KEY re_xxx) —
# Convex functions cannot read this file.
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Polar (billing tiers)
# ─────────────────────────────────────────────────────────────
# Read in convex/polar.ts; each falls back to an empty string, which disables
# that pricing tier rather than crashing. Only needed once you configure
# products in Polar and want that specific tier purchasable.
# Get product IDs from: Polar Dashboard → your organization → Products
# POLAR_ACCESS_TOKEN / POLAR_ORGANIZATION_TOKEN / POLAR_WEBHOOK_SECRET / POLAR_SERVER
# are read by the @convex-dev/polar component and must be set in the Convex
# dashboard (pnpm exec convex env set ...), never in this file — they are backend-only.
# POLAR_PRODUCT_TIER_1=
# POLAR_PRODUCT_TIER_2=
# POLAR_PRODUCT_TIER_3=

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Firecrawl (brand-kit / competitor scraping)
# ─────────────────────────────────────────────────────────────
# Read in convex/lib/firecrawl.ts. Absent key: a named FirecrawlKeyMissingError
# is thrown and surfaced as a `configMissing: true` banner on the affected
# feature — never a silent failure. Get from: https://firecrawl.dev/app/api-keys
# FIRECRAWL_API_KEY=

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Site URL overrides (SEO / CORS)
# ─────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SITE_URL: read in app/layout.tsx, app/robots.ts, app/sitemap.ts,
# and the accessibility pages, for canonical/OG metadata. Falls back to
# https://vantagestarter.ai (our own domain) — set this to YOUR production
# domain before going live, or SEO metadata will point at ours.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
#
# NEXT_PUBLIC_APP_URL: read in convex/http/orchestration.ts to restrict CORS
# on Convex HTTP actions (instead of a wildcard). Falls back to
# https://vantagestarter.com. Set this to YOUR domain in production.
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# ─────────────────────────────────────────────────────────────
# TOOLING — E2E testing (Playwright), never read by the running app
# ─────────────────────────────────────────────────────────────
# Clerk Testing Mode — OTP bypass for e2e authenticated tests.
# Generate from: Clerk Dashboard → Testing → Testing tokens
# Auth-required e2e tests skip automatically when this is absent.
CLERK_TESTING_TOKEN=

# Base URL for Playwright tests (defaults to http://localhost:3000)
PLAYWRIGHT_BASE_URL=http://localhost:3000
