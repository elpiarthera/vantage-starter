{
	"name": "vantage-starter",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"build": "next build --webpack",
		"prebuild": "node scripts/build-litui.mjs && node scripts/check-production-env.mjs --scope=\"${VERCEL_ENV:-development}\"",
		"check-production-env": "node scripts/check-production-env.mjs",
		"codegen": "convex codegen",
		"build:litui": "node scripts/build-litui.mjs",
		"dev": "next dev",
