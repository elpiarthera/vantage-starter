.turbo
package-lock.json

# clerk configuration (can include secrets)
/.clerk/

# Claude Code orchestration — the config directory is code (fleet rule
# claude-config-is-code) and ships in git. Only per-machine state and
# runtime artifacts are ignored below.
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/agent-memory/
# `*.bak.*` exigeait un POINT apres `.bak` : `settings.json.bak-bypass` (tiret)
# passait au travers et a ete commite. `*.bak*` couvre les deux separateurs,
# et le suffixe nu (`settings.json.bak`).
.claude/**/*.bak*
.claude/**/__pycache__/

# NO orchestrator-personal exclusions live here, by decision (PR #14).
# This block used to name eleven of them — 5 hooks + 6 skills, once committed as
# symlinks to absolute VPS paths. Every one of those rules is gone: the files are
# tracked, their content is in the tree, and `git ls-files .claude/` counts them.
# The eleven were the single cause of three outages in one session: an ignored file
# is invisible to git, so a checkout deletes it in silence, outside the conflict list.
# Tracking them is the only fix — git refuses to clobber a tracked file and says so
# out loud. Two of the eleven rules guarded files that never existed; only deriving
# the count revealed it, which is why no count is typed by hand here.
# Anything added below must be per-machine STATE, never configuration.

# Debug screenshots
*.png
!public/**/*.png

# Clerk keyless mode
.clerk/

# lit-ui bundle — generated by `pnpm prebuild` (scripts/build-litui.mjs).
# Tracking it made every build dirty the working tree.
/public/lit-ui/bundle.js
