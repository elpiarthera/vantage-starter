{
  "permissions": {
    "allow": [
      "Read(.claude/**)",
      "Read(CLAUDE.md)",
      "Read(CHANGELOG.md)",
      "Read(package.json)",
      "Read(tsconfig.json)",
      "Read(next.config.*)",
      "Read(components/**)",
      "Read(app/**)",
      "Read(content/**)",
      "Read(lib/**)",
      "Read(messages/**)",
      "Agent(*)",
      "Skill(*)",
      "mcp__vantage-peers__*",
      "mcp__convex__*"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/coding/vantage-starter/.claude/hooks/session-start-tau.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/coding/vantage-starter/.claude/hooks/enforce-component-brief.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write || Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/coding/vantage-starter/.claude/hooks/check-file-size.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
