{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/coding/vantage-starter/.claude/hooks/session-start.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/coding/vantage-starter/.claude/hooks/enforce-brief-template.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 /root/coding/vantage-starter/.claude/hooks/enforce-run-in-background.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 /root/coding/vantage-starter/.claude/hooks/enforce-repo-routing.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/coding/vantage-starter/.claude/hooks/block-orchestrator-code-edits.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__send_message",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/coding/vantage-starter/.claude/hooks/block-task-in-message.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 /root/coding/vantage-starter/.claude/hooks/enforce-no-task-in-message.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/coding/vantage-starter/.claude/hooks/enforce-git-pull-before-branch.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 /root/coding/vantage-starter/.claude/hooks/block-deploy-without-qa.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 /root/coding/vantage-starter/.claude/hooks/auto-inject-signature.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 /root/coding/vantage-starter/.claude/hooks/enforce-eta-approval-before-npm-publish.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/enforce-pi-authorization-before-prod-deploy.py"
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__delete_task|mcp__vantage-peers__delete_mission|mcp__vantage-peers__delete_message",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/coding/vantage-starter/.claude/hooks/block-delete-on-prod.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__start_task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/coding/vantage-starter/.claude/hooks/enforce-irp-sequence.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__send_message",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/enforce-ship-24-7.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__create_task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/enforce-ship-24-7.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__update_task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/enforce-ship-24-7.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__complete_task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/enforce-ship-24-7.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/enforce-friction-field.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__create_mission",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__update_mission",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__create_briefing_note",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__store_memory",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__write_diary",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__vantage-peers__send_message",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantage-starter/.claude/hooks/enforce-evidence-bound-notify.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__(complete_task|block_task|delete_task|bulk_complete_tasks|update_task)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/coding/vantage-starter/.claude/hooks/irp-breadcrumb.py",
            "timeout": 3
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npx convex deploy:*)",
      "Bash(npx convex run:*)",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Bash(*)",
      "Agent(*)",
      "Glob(*)",
      "Grep(*)",
      "Write(.claude/skills/**/*.md)",
      "Write(.claude/skills/**/*.json)",
      "Edit(.claude/skills/**/*.md)",
      "Edit(.claude/skills/**/*.json)",
      "Write(.claude/agents/**/*.md)",
      "Edit(.claude/agents/**/*.md)",
      "Write(.claude/hooks/**/*.py)",
      "Edit(.claude/hooks/**/*.py)",
      "Write(.claude/commands/**/*.md)",
      "Edit(.claude/commands/**/*.md)"
    ],
    "deny": [
      "Write(**/.ssh/**)",
      "Edit(**/.ssh/**)",
      "Read(**/.ssh/**)",
      "Write(.claude/settings.json)",
      "Edit(.claude/settings.json)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "defaultMode": "bypassPermissions",
  "permissionMode": "bypassPermissions"
}